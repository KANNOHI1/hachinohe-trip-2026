---
import StatusBadge from './StatusBadge.astro';
import type { Place } from '../data/trip';

interface Props {
  place: Place;
}

const { place } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const imageSrc = place.image ? `${base}${place.image.replace(/^\/+/, '')}` : undefined;
const items = [...(place.address ? [place.address] : []), ...place.memo, ...place.tags.map((tag) => `#${tag}`)];
---

<article class="card place-card">
  {imageSrc && <img class="place-image" src={imageSrc} alt={place.name} loading="lazy" />}
  <div class="place-body">
    <div class="split-title">
      <h3>{place.name}</h3>
      <StatusBadge status={place.status} />
    </div>
    <ul class="list">
      {items.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
    <a class="text-link" href={place.mapUrl} target="_blank" rel="noreferrer">地図を見る</a>
  </div>
</article>

<style>
  .place-card {
    overflow: hidden;
  }

  .place-image {
    aspect-ratio: 16 / 9;
    border-radius: var(--radius) var(--radius) 0 0;
    display: block;
    object-fit: cover;
    width: 100%;
  }

  .place-body {
    padding: 1rem;
  }

  .place-card h3 {
    font-size: 1.08rem;
  }

  .text-link {
    color: var(--color-teal);
    display: inline-flex;
    font-weight: 800;
    margin-top: 0.9rem;
  }
</style>
