---
import StatusBadge from './StatusBadge.astro';
import type { Status } from '../data/trip';

interface Props {
  title: string;
  body?: string;
  items?: string[];
  status?: Status;
  href?: string;
  hrefLabel?: string;
  image?: string;
}

const { title, body, items = [], status, href, hrefLabel = '地図を見る', image } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const imageSrc = image ? `${base}${image.replace(/^\/+/, '')}` : undefined;
---

<article class="card card-pad info-card">
  {imageSrc && <img class="info-thumb" src={imageSrc} alt={title} loading="lazy" />}
  <div class="split-title">
    <h3>{title}</h3>
    {status && <StatusBadge status={status} />}
  </div>
  {body && <p>{body}</p>}
  {
    items.length > 0 && (
      <ul class="list">
        {items.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    )
  }
  {href && <a class="text-link" href={href} target="_blank" rel="noreferrer">{hrefLabel}</a>}
</article>

<style>
  .info-card h3 {
    font-size: 1.08rem;
  }

  .info-thumb {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: 12px;
    margin-bottom: 0.85rem;
  }

  .text-link {
    display: inline-flex;
    margin-top: 0.9rem;
    color: var(--color-teal);
    font-weight: 800;
  }
</style>
