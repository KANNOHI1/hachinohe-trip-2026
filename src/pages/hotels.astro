---
import Layout from '../layouts/Layout.astro';
import SectionTitle from '../components/SectionTitle.astro';
import HotelCard from '../components/HotelCard.astro';
import { hotels } from '../data/trip';
---

<Layout title="Hotels">
  <header class="page-header">
    <h1>Hotels</h1>
    <p>「思い出になる宿」を優先。客室露天風呂、リゾート、温泉、自然、こもれる宿を重視した候補です。</p>
  </header>

  <div class="notice">
    <strong>要確認</strong>
    料金・空室・客室露天風呂付き客室の有無は予約前に再確認します。
  </div>

  <SectionTitle title="宿候補" />
  <section class="grid two">
    {hotels.map((hotel) => <HotelCard hotel={hotel} />)}
  </section>
</Layout>
