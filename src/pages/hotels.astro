---
import Layout from '../layouts/Layout.astro';
import SectionTitle from '../components/SectionTitle.astro';
import HotelCard from '../components/HotelCard.astro';
import { hotels } from '../data/trip';
---

<Layout title="Hotels">
  <header class="page-header">
    <h1>Hotels</h1>
    <p>三沢空港IN/OUTを前提に、十和田リゾート・酸ヶ湯・奥入瀬/蔦温泉・八戸中心街を比較します。全プラン3泊目は八戸です。</p>
  </header>

  <div class="notice">
    <strong>要確認</strong>
    料金・空室・客室露天風呂付き客室の有無は予約前に再確認します。
  </div>

  <SectionTitle title="宿候補" />
  <section class="grid two">
    {hotels.map((hotel) => <HotelCard hotel={hotel} />)}
  </section>
</Layout>
