---
import Layout from '../layouts/Layout.astro';
import SectionTitle from '../components/SectionTitle.astro';
import HotelCard from '../components/HotelCard.astro';
import { hotels, wishlistHotels } from '../data/trip';
---

<Layout title="Hotels">
  <header class="page-header">
    <h1>Hotels</h1>
    <p>Plan A（龍泉洞泊＋八戸ベース）で実際に泊まる宿です。料金・空室・客室露天風呂付き客室の有無は予約前に再確認します。</p>
  </header>

  <div class="notice">
    <strong>要確認</strong>
    料金・空室・客室露天風呂付き客室の有無は予約前に再確認します。
  </div>

  <SectionTitle title="宿候補" />
  <section class="grid two">
    {hotels.map((hotel) => <HotelCard hotel={hotel} />)}
  </section>

  <SectionTitle title="来年行きたい宿" description="今年は見送り。次の機会に。" />
  <section class="grid two">{wishlistHotels.map((hotel) => <HotelCard hotel={hotel} />)}</section>
</Layout>
