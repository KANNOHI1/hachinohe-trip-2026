---
import Layout from '../layouts/Layout.astro';
import SectionTitle from '../components/SectionTitle.astro';
import PlaceCard from '../components/PlaceCard.astro';
import { places } from '../data/trip';

const imageCredits = places.filter((place) => place.imageCredit);
---

<Layout title="Places">
  <header class="page-header">
    <h1>Places</h1>
    <p>蕪嶋神社、弁天島の厳島神社、種差海岸を中心に、海岸線ドライブへ組み込みたい場所を整理しています。</p>
  </header>

  <div class="notice">
    <strong>要確認</strong>
    天候、宿の場所、最終日の空港に合わせて回る順番を調整します。
  </div>

  <SectionTitle title="行きたい場所" />
  <section class="grid two">
    {places.map((place) => <PlaceCard place={place} />)}
  </section>

  <section class="image-credits" aria-label="画像クレジット">
    <h2>画像クレジット</h2>
    <ul>
      {imageCredits.map((place) => (
        <li>{place.imageCredit}</li>
      ))}
    </ul>
  </section>
</Layout>

<style>
  .image-credits {
    border-top: 1px solid var(--color-line);
    color: var(--color-muted);
    font-size: 0.82rem;
    margin-top: 2rem;
    padding-top: 1rem;
  }

  .image-credits h2 {
    color: var(--color-muted);
    font-size: 0.9rem;
    margin: 0 0 0.5rem;
  }

  .image-credits ul {
    display: grid;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
</style>
