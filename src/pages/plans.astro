---
import Layout from '../layouts/Layout.astro';
import SectionTitle from '../components/SectionTitle.astro';
import PlanCard from '../components/PlanCard.astro';
import { aomoriFallbackNote, plans } from '../data/trip';
---

<Layout title="Plans">
  <header class="page-header">
    <h1>Plans</h1>
    <p>三沢空港IN / 三沢空港OUTを前提に、龍泉洞・長流寺・八戸をどう組むかの A/B/C 比較です。</p>
  </header>

  <div class="notice">
    <strong>判断ポイント</strong>
    9/23の三沢→丘珠 JAL2816 の運航有無だけ要確認。全プラン共通でレンタカー、龍泉洞訪問、最終日の長流寺墓参→三沢OUTです。
  </div>

  <SectionTitle title="龍泉洞ベースプラン A/B/C" />
  <section class="grid three">
    {plans.map((plan) => <PlanCard plan={plan} />)}
  </section>
  <p style="margin-top: 1rem; color: var(--color-muted); font-size: 0.9rem;">{aomoriFallbackNote}</p>
</Layout>
