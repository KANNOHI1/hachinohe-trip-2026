---
import Layout from '../layouts/Layout.astro';
import SectionTitle from '../components/SectionTitle.astro';
import InfoCard from '../components/InfoCard.astro';
import PlanCard from '../components/PlanCard.astro';
import { checklist, flights, plans, tripOverview } from '../data/trip';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const keyChecks = checklist.filter((item) => item.status === 'check').slice(0, 5);
---

<Layout hero>
  <section class="hero" style={`--hero-image: url('${base}hero.png')`} slot="hero">
    <div class="hero-content">
      <h1>{tripOverview.title}</h1>
      <p>{tripOverview.dateLabel}</p>
    </div>
  </section>

  <header class="page-header">
    <h1>旅の現在地</h1>
    <p>{tripOverview.dateRange}。三沢空港IN / 三沢空港OUTを前提に、龍泉洞・長流寺・八戸を軸にした静的しおりです。</p>
  </header>

  <section class="grid two">
    <InfoCard title="基本方針" items={tripOverview.policy} />
  </section>

  <SectionTitle title="プラン比較（A / B / C）" description="本命は Plan A（八戸ベース＋龍泉洞泊）。B/Cは泊まり方違いの別案。" />
  <section class="plan-comparison" aria-label="プラン比較">
    {plans.map((plan) => (
      <div class:list={['plan-panel', plan.name === 'Plan A' && 'recommended']}>
        <PlanCard plan={plan} />
      </div>
    ))}
  </section>

  <SectionTitle title="重要な未確定事項" description="旅行の骨格に影響する確認項目だけを先に見える場所へ置いています。" />
  <section class="grid two">
    <InfoCard title="飛行機の前提" body="暫定便は決定済み（Flights参照）／確定は9月ダイヤ公開待ち。" status="check" />
    {flights.map((group) => <InfoCard title={group.title} body={group.note} status={group.status} />)}
    {keyChecks.map((item) => <InfoCard title={item.title} body={item.note} status={item.status} />)}
  </section>

  <SectionTitle title="次に決めること" />
  <section class="grid three">
    <InfoCard title="9月ダイヤ確認" body="三沢↔丘珠と羽田↔三沢の2026年9月ダイヤを公式発表後に確認。" status="check" />
    <InfoCard title="宿候補を絞る" body="Plan Aを軸に、八戸中心街とホテル龍泉洞愛山の空室・料金を確認。" status="tentative" />
    <InfoCard title="レンタカー条件" body="三沢空港IN / 三沢空港OUTの貸出・返却時刻と料金を確認。" status="check" />
  </section>
</Layout>

<style>
  .plan-comparison {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 0.5rem;
  }

  .plan-comparison > * {
    flex: 0 0 82vw;
    scroll-snap-align: start;
  }

  .plan-panel {
    scroll-snap-align: start;
  }

  .plan-panel.recommended {
    border-radius: var(--radius);
    outline: 2px solid rgba(192, 71, 59, 0.45);
    outline-offset: 3px;
  }

  @media (min-width: 768px) {
    .plan-comparison {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      overflow: visible;
    }

    .plan-comparison > * {
      flex: none;
    }
  }
</style>
