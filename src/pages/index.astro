---
import Layout from '../layouts/Layout.astro';
import SectionTitle from '../components/SectionTitle.astro';
import InfoCard from '../components/InfoCard.astro';
import { arrivalJourney, checklist, flights, plans, tripOverview } from '../data/trip';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const keyChecks = checklist.filter((item) => item.status === 'check').slice(0, 5);

const dayDates: Record<string, string> = {
  'Day 1': '9/20（日）',
  'Day 2': '9/21（月・祝）',
  'Day 3': '9/22（火・休日）',
  'Day 4': '9/23（水・祝）',
};

const plan = plans[0];

const stayLines = plan.summary.filter((line) => line.includes('泊目') && !/^Day\s*\d/.test(line));

const planA = {
  dayLines: plan.summary
    .filter((line) => /^Day\s*\d/.test(line))
    .map((line, index) => {
      const match = line.match(/^(Day\s*(\d))\s+(.+)$/);
      const day = match ? `Day ${match[2]}` : line;
      const stayLine = stayLines[index];
      return {
        day,
        date: dayDates[day] ?? '',
        body: match ? match[3] : line,
        status: day === 'Day 4' ? 'check' : plan.status,
        stay: stayLine ? stayLine.replace(/^\d+泊目[=＝]/, '') : null,
      };
    }),
};
---

<Layout hero>
  <section class="hero" style={`--hero-image: url('${base}hero.png')`} slot="hero">
    <div class="hero-content">
      <h1>{tripOverview.title}</h1>
      <p>{tripOverview.dateLabel}</p>
    </div>
  </section>

  <header class="page-header">
    <h1>旅の現在地</h1>
    <p>{tripOverview.dateRange}。三沢空港IN / 三沢空港OUTを前提に、龍泉洞・長流寺・八戸を軸にした静的しおりです。</p>
  </header>

  <section class="grid two">
    <InfoCard title="基本方針" items={tripOverview.policy} />
  </section>

  <SectionTitle title="旅の始まり — 9/20 三沢で合流" description="2本の移動が13:00に三沢空港で1本に。そのまま3泊4日の旅へ。" />
  <section class="arrival-story" aria-label="三沢空港での合流タイムライン">
    <div class="arrival-tracks">
      {arrivalJourney.tracks.map((track) => (
        <article class="arrival-track">
          <header>
            <p>{track.direction}</p>
            <h2>{track.person}</h2>
            <span>{track.origin} 出発</span>
          </header>
          <ol>
            {track.steps.map((step) => (
              <li>{step}</li>
            ))}
          </ol>
        </article>
      ))}
    </div>

    <div class="merge-node">
      <span class="merge-time">{arrivalJourney.merge.time}</span>
      <strong>{arrivalJourney.merge.place}</strong>
      <p>{arrivalJourney.merge.steps.join(' → ')}</p>
    </div>

    <ol class="day-timeline">
      {planA.dayLines.map((day) => (
        <li>
          <div class="day-marker"><strong>{day.day}</strong><span>{day.date}</span></div>
          <div class="day-card">
            <span class={`status-badge ${day.status}`}>{day.status === 'check' ? '要確認' : day.status === 'confirmed' ? '確定' : '未確定'}</span>
            <p>{day.body}</p>
            {day.stay && <p class="day-stay">宿: {day.stay}</p>}
          </div>
        </li>
      ))}
    </ol>
  </section>

  <SectionTitle title="重要な未確定事項" description="旅行の骨格に影響する確認項目だけを先に見える場所へ置いています。" />
  <section class="grid two">
    <InfoCard title="飛行機の前提" body="暫定便は決定済み（Flights参照）／確定は9月ダイヤ公開待ち。" status="check" />
    {flights.map((group) => <InfoCard title={group.title} body={group.note} status={group.status} />)}
    {keyChecks.map((item) => <InfoCard title={item.title} body={item.note} status={item.status} />)}
  </section>

  <SectionTitle title="次に決めること" />
  <section class="grid three">
    <InfoCard title="9月ダイヤ確認" body="三沢↔丘珠と羽田↔三沢の2026年9月ダイヤを公式発表後に確認。" status="check" />
    <InfoCard title="宿候補を絞る" body="八戸中心街とホテル龍泉洞愛山の空室・料金を確認。" status="tentative" />
    <InfoCard title="レンタカー条件" body="三沢空港IN / 三沢空港OUTの貸出・返却時刻と料金を確認。" status="check" />
  </section>
</Layout>

<style>
  .arrival-story {
    display: grid;
    gap: 1rem;
  }

  .arrival-tracks {
    display: grid;
    gap: 1rem;
  }

  .arrival-track {
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface);
    padding: 1rem;
  }

  .arrival-track header {
    display: grid;
    gap: 0.2rem;
    margin-bottom: 1rem;
  }

  .arrival-track header p {
    color: var(--color-muted);
    font-size: 0.85rem;
    margin: 0;
  }

  .arrival-track h2 {
    font-size: 1.35rem;
    margin: 0;
  }

  .arrival-track header span {
    color: var(--color-muted);
    font-size: 0.9rem;
  }

  .arrival-track ol,
  .day-timeline {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .arrival-track li {
    border-left: 2px solid rgba(192, 71, 59, 0.35);
    padding: 0 0 1rem 1rem;
    position: relative;
  }

  .arrival-track li:last-child {
    padding-bottom: 0;
  }

  .arrival-track li::before {
    background: var(--color-accent);
    border: 2px solid var(--color-surface);
    border-radius: 50%;
    content: '';
    height: 0.7rem;
    left: -0.43rem;
    position: absolute;
    top: 0.2rem;
    width: 0.7rem;
  }

  .merge-node {
    background: var(--color-accent);
    border-radius: var(--radius);
    color: white;
    padding: 1.2rem;
    text-align: center;
  }

  .merge-node strong {
    display: block;
    font-size: 1.35rem;
    margin: 0.15rem 0;
  }

  .merge-node p {
    margin: 0.35rem 0 0;
  }

  .merge-time {
    font-size: 0.95rem;
    font-weight: 700;
  }

  .day-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface);
  }

  .day-timeline {
    display: grid;
    gap: 0.85rem;
  }

  .day-timeline li {
    display: grid;
    gap: 0.55rem;
  }

  .day-marker {
    display: flex;
    gap: 0.5rem;
    justify-content: space-between;
  }

  .day-marker span {
    color: var(--color-muted);
  }

  .day-card {
    display: grid;
    gap: 0.5rem;
    padding: 0.9rem;
  }

  .day-card p {
    margin: 0;
  }

  .day-stay {
    color: var(--color-muted);
    font-size: 0.85rem;
    margin: 0;
  }

  .status-badge {
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 700;
    justify-self: start;
    padding: 0.25rem 0.55rem;
  }

  .status-badge.tentative {
    background: rgba(182, 124, 47, 0.16);
    color: #8a560f;
  }

  .status-badge.confirmed {
    background: rgba(46, 125, 50, 0.14);
    color: #2e7d32;
  }

  .status-badge.check {
    background: rgba(31, 91, 125, 0.14);
    color: #1f5b7d;
  }

  @media (min-width: 768px) {
    .arrival-tracks {
      grid-template-columns: repeat(2, 1fr);
    }

    .merge-node {
      justify-self: center;
      min-width: min(28rem, 100%);
    }

    .day-timeline li {
      align-items: start;
      grid-template-columns: 8rem 1fr;
    }

    .day-marker {
      display: grid;
      gap: 0.2rem;
      justify-content: start;
    }
  }
</style>
